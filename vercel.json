{
  "version": 2,
  "routes": [
    { "src": "/api/health", "dest": "/api/health" },
    { "src": "/api/(.*)",   "dest": "/api/$1"     },
    { "src": "/app.js",     "dest": "/public/app.js" },
    { "src": "/(.*\\.(js|css|png|jpg|ico|svg|woff2?))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*\\.(js|css|png|jpg|ico|svg|woff2?))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=3600" }
      ]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/analyze.js": { "maxDuration": 30 },
    "api/scanner.js": { "maxDuration": 30 },
    "api/health.js":  { "maxDuration": 10 }
  }
}
