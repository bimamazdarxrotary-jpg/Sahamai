# SahamAI — Environment Variables
# Copy file ini: cp .env.example .env
# Jangan commit .env ke Git!
# ══════════════════════════════════════════════════════════════════

# [WAJIB] API key dari console.groq.com — gratis tier tersedia
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# [OPSIONAL] Port local dev server (default: 3000)
PORT=3000

# [OPSIONAL] Mode environment — "production" untuk Vercel
NODE_ENV=development
