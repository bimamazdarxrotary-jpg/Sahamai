# ══════════════════════════════════════════════════════════════════
# SahamAI — Environment Variables
# Copy file ini: cp .env.example .env
# Jangan commit .env ke Git!
# ══════════════════════════════════════════════════════════════════

# [WAJIB] API key dari console.groq.com — gratis tier tersedia
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# [OPSIONAL] Model Groq yang dipakai (default: openai/gpt-oss-120b)
# Ganti tanpa perlu deploy ulang, cukup update env di Vercel dashboard
GROQ_MODEL=openai/gpt-oss-120b

# [OPSIONAL] Port local dev server (default: 3000)
PORT=3000

# [OPSIONAL] Mode environment — "production" untuk Vercel
NODE_ENV=development

# [OPSIONAL] Log level: debug | info | warn | error (default: debug di dev, info di prod)
LOG_LEVEL=info
