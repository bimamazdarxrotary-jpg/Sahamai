# ══════════════════════════════════════════════════════════════════
# .env.example — Salin file ini ke .env dan isi nilainya
# cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── Wajib ─────────────────────────────────────────────────────────
# API key dari https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Opsional ──────────────────────────────────────────────────────
# Port untuk local dev server (default: 3000)
PORT=3000

# Environment (development / production)
NODE_ENV=development
